@using Volo.Abp.AspNetCore.Components.Web
@if (AccessToken.IsNullOrWhiteSpace())
{
    <script>localStorage.removeItem('@PersistentAccessToken.Key');</script>
}
@code
{
    [Parameter]
    public string? AccessToken { get; set; }

    protected ILocalStorageService LocalStorageService { get; }

    public PersistentAccessTokenToClient(ILocalStorageService localStorageService)
    {
        LocalStorageService = localStorageService;
    }

    protected override async Task OnInitializedAsync()
    {
        if (OperatingSystem.IsBrowser() || AccessToken.IsNullOrWhiteSpace())
        {
            return;
        }

        await LocalStorageService.SetItemAsync(PersistentAccessToken.Key, AccessToken);
    }
}
